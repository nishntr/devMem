{
  "name": "recall-vscode",
  "displayName": "Recall",
  "description": "Developer memory layer — captures workspace activity for dev-recall",
  "version": "0.1.0",
  "publisher": "dev-recall",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Recall",
      "properties": {
        "recall.port": {
          "type": "number",
          "default": 27182,
          "description": "Port for the Recall daemon HTTP server"
        },
        "recall.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable the Recall VS Code extension"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
